{
  "annotations": {"list": []},
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "gridPos": {"h": 5, "w": 4, "x": 0, "y": 0},
      "id": 1,
      "options": {"colorMode": "value", "graphMode": "area", "justifyMode": "auto", "textMode": "auto"},
      "targets": [{"expr": "iot_devices_total", "refId": "A"}],
      "title": "Fleet Devices",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "percent"}, "overrides": []},
      "gridPos": {"h": 5, "w": 4, "x": 4, "y": 0},
      "id": 2,
      "options": {"colorMode": "value", "graphMode": "area", "justifyMode": "auto", "textMode": "auto"},
      "targets": [{"expr": "avg(iot_device_soc_percent)", "refId": "A"}],
      "title": "Average SOC",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "gridPos": {"h": 5, "w": 4, "x": 8, "y": 0},
      "id": 3,
      "options": {"colorMode": "value", "graphMode": "area", "justifyMode": "auto", "textMode": "auto"},
      "targets": [{"expr": "count(iot_device_soc_percent < 10)", "refId": "A"}],
      "title": "Critical SOC",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "gridPos": {"h": 5, "w": 4, "x": 12, "y": 0},
      "id": 4,
      "options": {"colorMode": "value", "graphMode": "area", "justifyMode": "auto", "textMode": "auto"},
      "targets": [{"expr": "count(time() - iot_device_last_seen_timestamp_seconds > 300)", "refId": "A"}],
      "title": "Offline Devices",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "ops"}, "overrides": []},
      "gridPos": {"h": 5, "w": 8, "x": 16, "y": 0},
      "id": 5,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "targets": [{"expr": "sum by (result) (rate(iot_telemetry_ingested_total[1m]))", "legendFormat": "{{result}}", "refId": "A"}],
      "title": "Ingestion Rate",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1}, "overrides": []},
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 5},
      "id": 6,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "single"}},
      "targets": [{"expr": "iot_ingestion_queue_depth / iot_ingestion_queue_capacity", "refId": "A"}],
      "title": "Queue Utilization",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "percent"}, "overrides": []},
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 5},
      "id": 7,
      "options": {"legend": {"displayMode": "table", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "targets": [{"expr": "iot_device_soc_percent", "legendFormat": "{{device_id}}", "refId": "A"}],
      "title": "Device SOC",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "celsius"}, "overrides": []},
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 5},
      "id": 8,
      "options": {"legend": {"displayMode": "table", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "targets": [{"expr": "iot_device_temperature_celsius", "legendFormat": "{{device_id}}", "refId": "A"}],
      "title": "Device Temperature",
      "type": "timeseries"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 41,
  "tags": ["iot", "golang", "prometheus"],
  "templating": {"list": []},
  "time": {"from": "now-30m", "to": "now"},
  "timezone": "browser",
  "title": "Go IoT Fleet Observability",
  "uid": "go-iot-fleet",
  "version": 1
}

